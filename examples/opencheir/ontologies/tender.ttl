@prefix : <http://opencheir.org/tender#> .
@prefix doc: <http://opencheir.org/document#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Tender Domain Ontology ---
# Models tender concepts: specs, requirements, lots, criteria,
# case studies, staff, pricing, workflow steps.

:Tender a owl:Class ;
    rdfs:label "Tender" ;
    rdfs:comment "A public procurement tender opportunity" .

:Specification a owl:Class ;
    rdfs:subClassOf doc:PdfDocument ;
    rdfs:label "Specification" ;
    rdfs:comment "The ITT, spec, or requirements document" .

:Clarification a owl:Class ;
    rdfs:subClassOf doc:PdfDocument ;
    rdfs:label "Clarification" ;
    rdfs:comment "Buyer clarification document" .

:Response a owl:Class ;
    rdfs:subClassOf doc:DocxDocument ;
    rdfs:label "Response" ;
    rdfs:comment "Supplier tender response document" .

:Lot a owl:Class ;
    rdfs:label "Lot" ;
    rdfs:comment "A tender lot (subdivision of contract)" .

:Requirement a owl:Class ;
    rdfs:label "Requirement" ;
    rdfs:comment "A spec requirement extracted from tender documents" .

:EvaluationCriterion a owl:Class ;
    rdfs:label "Evaluation Criterion" ;
    rdfs:comment "How the tender will be scored" .

:CaseStudy a owl:Class ;
    rdfs:label "Case Study" ;
    rdfs:comment "Past project evidence" .

:StaffMember a owl:Class ;
    rdfs:label "Staff Member" ;
    rdfs:comment "Named team member proposed for delivery" .

:PricingSchedule a owl:Class ;
    rdfs:label "Pricing Schedule" ;
    rdfs:comment "Cost breakdown and pricing table" .

:WorkflowStep a owl:Class ;
    rdfs:label "Workflow Step" ;
    rdfs:comment "A step in the tender pipeline" .

# --- Requirement Properties ---

:isMandatory a owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:boolean .

:requirementId a owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string .

:description a owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string .

:pageRef a owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:integer .

:category a owl:DatatypeProperty ;
    rdfs:domain :Requirement ;
    rdfs:range xsd:string ;
    rdfs:comment "Tag: data_protection, staffing, methodology, pricing, etc." .

# --- Tender Structure ---

:hasLot a owl:ObjectProperty ;
    rdfs:domain :Tender ;
    rdfs:range :Lot .

:hasSpecification a owl:ObjectProperty ;
    rdfs:domain :Tender ;
    rdfs:range :Specification .

:hasClarification a owl:ObjectProperty ;
    rdfs:domain :Tender ;
    rdfs:range :Clarification .

:hasResponse a owl:ObjectProperty ;
    rdfs:domain :Lot ;
    rdfs:range :Response .

:hasRequirement a owl:ObjectProperty ;
    rdfs:domain :Specification ;
    rdfs:range :Requirement .

:hasCriterion a owl:ObjectProperty ;
    rdfs:domain :Tender ;
    rdfs:range :EvaluationCriterion .

# --- Scoring ---

:weight a owl:DatatypeProperty ;
    rdfs:domain :EvaluationCriterion ;
    rdfs:range xsd:float ;
    rdfs:comment "Percentage weight in evaluation (e.g. 60 for quality)" .

:maxScore a owl:DatatypeProperty ;
    rdfs:domain :EvaluationCriterion ;
    rdfs:range xsd:integer .

# --- Case Studies ---

:hasCaseStudy a owl:ObjectProperty ;
    rdfs:domain :Response ;
    rdfs:range :CaseStudy .

:projectName a owl:DatatypeProperty ;
    rdfs:domain :CaseStudy ;
    rdfs:range xsd:string .

:clientName a owl:DatatypeProperty ;
    rdfs:domain :CaseStudy ;
    rdfs:range xsd:string .

:contractValue a owl:DatatypeProperty ;
    rdfs:domain :CaseStudy ;
    rdfs:range xsd:decimal .

:domain a owl:DatatypeProperty ;
    rdfs:domain :CaseStudy ;
    rdfs:range xsd:string ;
    rdfs:comment "Must match tender domain — AI case studies don't score for safeguarding" .

# --- Staff ---

:hasStaff a owl:ObjectProperty ;
    rdfs:domain :Response ;
    rdfs:range :StaffMember .

:role a owl:DatatypeProperty ;
    rdfs:domain :StaffMember ;
    rdfs:range xsd:string .

:yearsExperience a owl:DatatypeProperty ;
    rdfs:domain :StaffMember ;
    rdfs:range xsd:integer .

# --- Pricing ---

:hasPricing a owl:ObjectProperty ;
    rdfs:domain :Response ;
    rdfs:range :PricingSchedule .

:budgetEnvelope a owl:DatatypeProperty ;
    rdfs:domain :Tender ;
    rdfs:range xsd:decimal .

:bidPrice a owl:DatatypeProperty ;
    rdfs:domain :PricingSchedule ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Always bid 70% of budget envelope" .

# --- Workflow ---

:hasStep a owl:ObjectProperty ;
    rdfs:domain :Tender ;
    rdfs:range :WorkflowStep .

:stepOrder a owl:DatatypeProperty ;
    rdfs:domain :WorkflowStep ;
    rdfs:range xsd:integer .

:stepName a owl:DatatypeProperty ;
    rdfs:domain :WorkflowStep ;
    rdfs:range xsd:string .

:completedAt a owl:DatatypeProperty ;
    rdfs:domain :WorkflowStep ;
    rdfs:range xsd:dateTime .

# --- Bid Decision ---

:bidDecision a owl:DatatypeProperty ;
    rdfs:domain :Tender ;
    rdfs:range xsd:string ;
    rdfs:comment "bid or no-bid" .

:subcontractPercentage a owl:DatatypeProperty ;
    rdfs:domain :Tender ;
    rdfs:range xsd:float ;
    rdfs:comment "Must be <30% to bid" .

:capabilityScore a owl:DatatypeProperty ;
    rdfs:domain :Tender ;
    rdfs:range xsd:float ;
    rdfs:comment "Must be >80% to bid" .
