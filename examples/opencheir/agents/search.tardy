// OpenCheir — FTS5 Search Engine
//
// Full-text search across all indexed tender documents.
// Uses SQLite FTS5 for BM25 ranked retrieval.
// Indexes both DOCX text and PDF extracted text.

agent SearchEngine @verified {
    let query: Fact = receive("search query across tender documents") @verified

    // Initialize FTS5 table if not exists
    let init_db: str = exec("sqlite3 tender.db 'CREATE VIRTUAL TABLE IF NOT EXISTS docs USING fts5(source, title, content)'")

    // Run BM25 ranked search
    let results: str = exec("sqlite3 -json tender.db 'SELECT source, title, snippet(docs, 2, \">\", \"<\", \"...\", 32), rank FROM docs WHERE docs MATCH ? ORDER BY rank LIMIT 20'")

    // Get result count
    let count: str = exec("sqlite3 tender.db 'SELECT COUNT(*) FROM docs WHERE docs MATCH ?'")

    grounded_in(tender)
    invariant(trust_min: @verified)
}
