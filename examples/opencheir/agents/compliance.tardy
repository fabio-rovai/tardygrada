// OpenCheir — Compliance Matrix
//
// Matches spec requirements against response sections.
// Two-layer matching:
//   1. FTS5 keyword matching — explicit requirement references
//   2. Tag-based matching — semantic category alignment
// Flags unmatched requirements as gaps.

agent ComplianceChecker @verified @semantics(
    truth.min_confidence: 0.90,
    truth.min_consensus_agents: 3
) {
    // Receive extracted requirements (from extract_reqs.tardy)
    let requirements: Fact = receive("list of spec requirements with page references") @verified

    // Receive response sections
    let response_sections: Fact = receive("list of response sections with content") @verified

    // FTS5 keyword match: find response sections mentioning requirement IDs
    let keyword_matches: str = exec("sqlite3 -json tender.db 'SELECT r.req_id, d.title, d.source, rank FROM requirements r, docs d WHERE d.content MATCH r.keywords ORDER BY r.req_id, rank LIMIT 100'")

    // Tag match: find sections sharing requirement tags
    let tag_matches: str = exec("sqlite3 -json tender.db 'SELECT r.req_id, r.tag, s.section_id, s.tag FROM req_tags r JOIN section_tags s ON r.tag = s.tag'")

    // Gap detection: requirements with no matches
    let gaps: str = exec("sqlite3 -json tender.db 'SELECT req_id, description FROM requirements WHERE req_id NOT IN (SELECT DISTINCT req_id FROM compliance_matches)'")

    grounded_in(compliance)
    invariant(trust_min: @verified)
}
