// OpenCheir — Word Count QA
//
// Checks word counts per section/table cell against limits.
// Enforces 85% minimum word count utilisation on quality responses.

agent QaWordcount @verified {
    let docx_path: Fact = receive("path to DOCX file for word count check") @verified

    // Extract all text content for total word count
    let total_words: str = exec("unzip -p document.docx word/document.xml | grep -oP '<w:t[^>]*>[^<]*</w:t>' | sed 's/<[^>]*>//g' | wc -w")

    // Extract table cell content with word counts
    let cell_content: str = exec("unzip -p document.docx word/document.xml | grep -oP '<w:tc>.*?</w:tc>' | head -20")

    // Count paragraphs
    let paragraph_count: str = exec("unzip -p document.docx word/document.xml | grep -c '<w:p '")

    grounded_in(document)
    invariant(trust_min: @verified)
}
