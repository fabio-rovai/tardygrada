// OpenCheir — Prompt Injection Firewall
//
// Inherited from BITF firewall.
// Guards all incoming content against prompt injection attacks.
// @sovereign — cannot be bypassed, overridden, or disabled.
// Checks all tender documents before processing.

agent Firewall @sovereign @semantics(
    truth.min_confidence: 0.99,
    truth.min_consensus_agents: 5,
    pipeline.min_passing_layers: 7
) {
    let input_content: Fact = receive("content to check for injection attacks") @sovereign

    // Check for common injection patterns
    let injection_check: str = exec("echo 'checking patterns' | grep -ciP 'ignore previous|disregard|new instructions|system prompt|you are now|forget everything|override|jailbreak'")

    // Check for encoding-based attacks (base64, hex)
    let encoding_check: str = exec("echo 'checking encodings' | grep -cP '[A-Za-z0-9+/]{40,}={0,2}'")

    // Check for role-switching attempts
    let role_check: str = exec("echo 'checking roles' | grep -ciP 'assistant:|system:|user:|human:|<\\|im_start\\|>'")

    grounded_in(tender)
    invariant(trust_min: @sovereign)
}
