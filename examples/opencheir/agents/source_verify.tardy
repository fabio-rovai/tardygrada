// OpenCheir — Source Quote Verification
//
// Inherited from BITF.
// Every claim in a tender response must be backed by an exact quote
// from the spec or a verifiable source.
// Catches fabrication: invented frameworks, fake project references,
// fabricated citations, fictional staff.

agent SourceVerifier @verified @semantics(
    truth.min_confidence: 0.90,
    truth.min_consensus_agents: 3
) {
    let response_claim: Fact = receive("claim from tender response to verify") @verified
    let source_document: Fact = receive("source document to verify against") @verified

    // Search for exact quote in source document via FTS5
    let quote_match: str = exec("sqlite3 -json tender.db 'SELECT source, snippet(docs, 2, \">\", \"<\", \"...\", 64), rank FROM docs WHERE docs MATCH ? ORDER BY rank LIMIT 5'")

    // Check if cited case study exists in company records
    let case_study_check: str = exec("sqlite3 tender.db 'SELECT COUNT(*) FROM case_studies WHERE title MATCH ?'")

    // Check if named staff exist in company records
    let staff_check: str = exec("sqlite3 tender.db 'SELECT COUNT(*) FROM staff WHERE name MATCH ?'")

    grounded_in(tender)
    invariant(trust_min: @verified)
}
