// OpenCheir — DOCX Parser
//
// Extracts structure from DOCX files.
// DOCX is a ZIP archive containing word/document.xml.
// Extracts: paragraphs, tables, runs, font metadata.

agent DocxParser @verified {
    let docx_path: Fact = receive("path to DOCX file") @verified

    // Extract the main document XML from the DOCX ZIP archive
    let document_xml: str = exec("unzip -p document.docx word/document.xml")

    // Extract styles for font information
    let styles_xml: str = exec("unzip -p document.docx word/styles.xml")

    // Extract table content
    let tables: str = exec("unzip -p document.docx word/document.xml | grep -c '<w:tbl>'")

    // List all files in the archive for structure analysis
    let archive_contents: str = exec("unzip -l document.docx")

    grounded_in(document)
    invariant(trust_min: @verified)
}
