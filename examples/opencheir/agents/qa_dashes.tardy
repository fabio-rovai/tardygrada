// OpenCheir — Dash/Hyphen Consistency QA
//
// Detects inconsistent dash usage in DOCX files.
// Checks for mixing of: hyphen (-), en-dash (--), em-dash (---),
// minus sign, and Unicode variants.

agent QaDashes @verified {
    let docx_path: Fact = receive("path to DOCX file for dash check") @verified

    // Extract all text content and count dash variants
    let hyphens: str = exec("unzip -p document.docx word/document.xml | grep -oP '<w:t[^>]*>[^<]*</w:t>' | grep -c '\\-'")

    // Check for en-dash Unicode characters
    let en_dashes: str = exec("unzip -p document.docx word/document.xml | grep -c 'endash'")

    // Check for em-dash Unicode characters
    let em_dashes: str = exec("unzip -p document.docx word/document.xml | grep -c 'emdash'")

    // Extract raw text for dash context
    let text_content: str = exec("unzip -p document.docx word/document.xml | grep -oP '<w:t[^>]*>[^<]*</w:t>' | head -50")

    grounded_in(document)
    invariant(trust_min: @verified)
}
