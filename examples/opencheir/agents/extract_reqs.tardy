// OpenCheir — Requirement Extractor
//
// Extracts structured requirements from tender specifications.
// Each requirement becomes a verified claim with:
//   - Requirement ID
//   - Description
//   - Page reference
//   - Category tag
//   - Mandatory/desirable flag
// Stores in SQLite for compliance matching.

agent ReqExtractor @verified @semantics(
    truth.min_confidence: 0.90,
    truth.min_consensus_agents: 3
) {
    let spec_text: Fact = receive("extracted tender specification text with page numbers") @verified

    // Initialize requirements table
    let init_reqs: str = exec("sqlite3 tender.db 'CREATE TABLE IF NOT EXISTS requirements(req_id TEXT PRIMARY KEY, description TEXT, page INTEGER, tag TEXT, mandatory INTEGER, keywords TEXT)'")

    // Initialize tags table for compliance matching
    let init_tags: str = exec("sqlite3 tender.db 'CREATE TABLE IF NOT EXISTS req_tags(req_id TEXT, tag TEXT, FOREIGN KEY(req_id) REFERENCES requirements(req_id))'")

    // Search for numbered requirements (e.g. "3.1.2 The supplier shall...")
    let numbered_reqs: str = exec("pdftotext -layout spec.pdf - | grep -nP '^\\s*\\d+\\.\\d+' | head -50")

    // Search for mandatory language
    let mandatory_reqs: str = exec("pdftotext -layout spec.pdf - | grep -niP 'shall|must|required|mandatory' | head -50")

    grounded_in(tender)
    invariant(trust_min: @verified)
}
